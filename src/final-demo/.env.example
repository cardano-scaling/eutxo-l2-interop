DATABASE_URL="postgresql://postgres:postgres@localhost:5434/final_demo?schema=public"
WORKER_POLL_MS=2000
WORKER_QUEUE_METRICS_LOG_MS=30000
WORKFLOW_LOCK_MS=300000
HEAD_STATE_STALE_MS=60000
HEAD_SNAPSHOT_SYNC_MS=30000
REQUEST_FUNDS_MOCK_FAILURE_MODE=none
BUY_TICKET_MOCK_FAILURE_MODE=none
HYDRA_ADAPTER_MODE=real
HYDRA_OPERATION_TIMEOUT_MS=20000
HYDRA_HEAD_A_API_URL=http://localhost:4319
HYDRA_HEAD_B_API_URL=http://localhost:4329
# Jon's Hydra API (lottery mint / pay-winner; must match lottery datum admin key).
HYDRA_HEAD_B_JON_API_URL=http://localhost:4328
HYDRA_HEAD_C_API_URL=http://localhost:4339
HYDRA_OPS_DRAFT_TTL_MS=300000
CARDANO_NETWORK=custom
CARDANO_NETWORK_MAGIC=42
# Optional in local/private mode. Required in preprod/external mode.
CARDANO_QUERY_API_URL=
CARDANO_SUBMIT_API_URL=

# Optional. Default when admin leaves "Close timestamp" empty on lottery create (ms from now at mint time).
# Demo default in script is 30 minutes. Example for ~30d: LOTTERY_DEFAULT_CLOSE_DELAY_MS=2592000000
# LOTTERY_DEFAULT_CLOSE_DELAY_MS=
