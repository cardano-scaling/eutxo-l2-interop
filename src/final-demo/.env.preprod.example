DATABASE_URL=postgresql://postgres:postgres@postgres:5432/final_demo?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=final_demo

# Must match the Docker network created by the VM lottery compose.
LOTTERY_HYDRA_NETWORK=infra_hydra_net

# Host path to external Cardano node socket (mounted into sidecars).
# Example: /opt/cardano/ipc/node.socket
CARDANO_SOCKET_PATH=/path/to/node.socket
# Host path to Cardano node config JSON required by cardano-submit-api.
CARDANO_NODE_CONFIG_PATH=/path/to/preprod/cardano-node/config.json
# Optional explicit submit-api config path (use if VM provides a dedicated file).
# Falls back to CARDANO_NODE_CONFIG_PATH when unset.
# Example candidate paths to check:
# /data/cardano-configurations/network/preprod/cardano-submit-api/config.json
# /data/cardano-configurations/network/preprod/submit-api-config.json
CARDANO_SUBMIT_API_CONFIG_PATH=

# Final demo UI/API port exposed by overlay compose.
FINAL_DEMO_PORT=3000

# Hydra head APIs from the lottery topology.
HYDRA_HEAD_A_API_URL=http://hydra-node-ida-1-lt:4319
HYDRA_HEAD_B_API_URL=http://hydra-node-ida-2-lt:4329
# Jon's Hydra client (lottery mint / pay-winner txs are signed by Jon).
HYDRA_HEAD_B_JON_API_URL=http://hydra-node-jon-lt:4328
HYDRA_HEAD_C_API_URL=http://hydra-node-ida-3-lt:4339

# L1 HTTP APIs provided by overlay sidecars.
CARDANO_QUERY_API_URL=http://cardano-query-api:1442
CARDANO_SUBMIT_API_URL=http://cardano-submit-api:8090/api/submit/tx
CARDANO_QUERY_API_PORT=1442
CARDANO_SUBMIT_API_PORT=8090
CARDANO_SUBMIT_API_CONFIG_PATH=/path/to/cardano-submit-api/config.json

# Public testnet network config.
CARDANO_NETWORK=preprod
CARDANO_NETWORK_MAGIC=1

# Runtime tuning for slower public testnet acknowledgement.
HYDRA_ADAPTER_MODE=real
HYDRA_OPERATION_TIMEOUT_MS=90000
HEAD_OPERATION_TIMEOUT_MS=720000
HYDRA_OPS_DRAFT_TTL_MS=300000
WORKER_POLL_MS=2000


# Optional: ms from "now" when minting a lottery if admin omits close timestamp (default in script: 30 min for demos).
# LOTTERY_DEFAULT_CLOSE_DELAY_MS=2592000000

# Recommended in preprod: set passwords for the Admin and Charlie pages.
FINAL_DEMO_ADMIN_PASSWORD=admin-password
FINAL_DEMO_CHARLIE_PASSWORD=charlie-password

